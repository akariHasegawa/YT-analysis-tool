# Supabase（ユーザー管理・分析回数制限・統計 API）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI（必須）— Chat Completions API 用キー
OPENAI_API_KEY=

# 任意（既定: gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# 任意 — 設定すると再生回数・再生時間・いいね数を YouTube Data API v3 で取得（oEmbed 単体では取得不可）
# YOUTUBE_DATA_API_KEY=

# 任意 — Google Apps Script の Webhook URL（デプロイの「ウェブアプリ」URL）
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbzKRM4ynLYMkdZBV-FEC-8stl9hQ2DNOST5Hxk-RDOP3T3pdtgdiubqRnaugT9VlEIRfg/exec
# Stripe（サブスク）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=
# 例: https://your-domain.com（未設定時はリクエストのoriginを使用）
NEXT_PUBLIC_APP_URL=

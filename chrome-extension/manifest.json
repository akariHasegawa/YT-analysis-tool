{
  "manifest_version": 3,
  "name": "AIAI-short 分析ツール",
  "version": "1.0.0",
  "description": "TikTok・Instagram Reelsの動画データを自動収集してAIAI-shortで分析",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "tabs", "windows"],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://www.instagram.com/*",
    "https://yt-analysis-tool-mu.vercel.app/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://yt-analysis-tool-mu.vercel.app/*"],
      "js": ["content-scripts/auth.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tiktok.com/*", "https://tiktok.com/*"],
      "js": ["content-scripts/tiktok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content-scripts/instagram.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
